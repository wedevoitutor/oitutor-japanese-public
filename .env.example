# Frontend configuration
# Copy to .env for local development and fill with your own project values.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional Cloudflare Turnstile site key. In dev, the app has a test fallback.
VITE_TURNSTILE_SITE_KEY=
