    {
      "target": "price-vs-quantity",
      "error": "Answers いくら with a quantity instead of a price.",
      "mitigation": "Meaning checks and response-selection drills separate いくら from いくつ."
    },
    {
      "target": "native-counters",
      "error": "Uses plain numbers where native counters like みっつ are needed for things.",
      "mitigation": "Formula-fill and matching include native thing counters."
    },
    {
      "target": "age-vs-count",
      "error": "Confuses おいくつですか with asking how many items there are.",
      "mitigation": "Comparison cards and MC items distinguish age from quantity."
    },
    {
      "target": "sanbyaku-reading",
      "error": "Misreads さんびゃくえん as 30 yen or 300 items.",
      "mitigation": "Listening meaning checks contrast 300 yen with other number meanings."
    }
  ],
