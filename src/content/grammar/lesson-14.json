    {
      "type": "comparison-cards",
      "prompt": "Which sentence uses an i-adjective correctly before a noun?",
      "title": "i-adjective + noun",
      "variants": [
        {
          "label": "CORRECT",
          "jp": "おいしい りょうりです。",
          "romaji": "oishii ryouri desu.",
          "en": "It is delicious food.",
          "note": "The i-adjective goes directly before the noun.",
          "correct": true
        },
        {
          "label": "COMMON MISTAKE",
          "jp": "おいしいな りょうりです。",
          "romaji": "oishii na ryouri desu.",
          "en": "(intended: delicious food)",
          "note": "Regular i-adjectives do not take な before nouns.",
          "correct": false
        },
        {
          "label": "WRONG",
          "jp": "おいしく りょうりです。",
          "romaji": "oishiku ryouri desu.",
          "en": "(intended: delicious food)",
          "note": "おいしく is the adverb/connecting form, not the noun-modifying form.",
          "correct": false
        }
      ],
      "takeaway": "Put regular i-adjectives directly before nouns.",
      "speakText": "おいしい りょうりです。"
    },
    {
      "type": "comparison-cards",
      "prompt": "Which correctly says 'It is not cold'?",
      "title": "negative i-adjectives",
      "variants": [
        {
          "label": "CORRECT",
          "jp": "さむくないです。",
          "romaji": "samukunai desu.",
          "en": "It is not cold.",
          "note": "Replace final い with くない.",
          "correct": true
        },
        {
          "label": "COMMON MISTAKE",
          "jp": "さむいじゃないです。",
          "romaji": "samui ja nai desu.",
          "en": "(intended: not cold)",
          "note": "じゃない is for nouns and na-adjectives, not regular i-adjectives.",
          "correct": false
        },
        {
          "label": "WRONG",
          "jp": "さむいないです。",
          "romaji": "samui nai desu.",
          "en": "(intended: not cold)",
          "note": "Do not attach ない after the full present form.",
          "correct": false
        }
      ],
      "takeaway": "For i-adjectives, final い becomes くない.",
      "speakText": "さむくないです。"
    },
