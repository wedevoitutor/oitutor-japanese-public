    {
      "type": "reference-chart",
      "title": "i-Adjectives as Predicates",
      "intro": "i-adjectives can end a sentence by themselves, or politely with です. The final い is part of the adjective, so keep it in the present affirmative form.",
      "rows": [
        [
          "Japanese",
          "Romaji",
          "Meaning"
        ],
        [
          "おいしい",
          "oishii",
          "delicious"
        ],
        [
          "あつい",
          "atsui",
          "hot"
        ],
        [
          "さむい",
          "samui",
          "cold"
        ],
        [
          "たかい",
          "takai",
          "expensive / tall"
        ],
        [
          "やすい",
          "yasui",
          "cheap / easy"
        ],
        [
          "おもしろい",
          "omoshiroi",
          "interesting"
        ],
        [
          "かわいい",
          "kawaii",
          "cute"
        ]
