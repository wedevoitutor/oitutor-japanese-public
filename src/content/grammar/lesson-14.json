    {
      "type": "reference-chart",
      "title": "Negative and Past i-Adjectives",
      "intro": "To conjugate an i-adjective, replace the final い. This gives the negative, past, and past-negative forms used in everyday descriptions.",
      "rows": [
        [
          "Form",
          "Japanese",
          "Romaji"
        ],
        [
          "present",
          "たかい",
          "takai"
        ],
        [
          "negative",
          "たかくない",
          "takakunai"
        ],
        [
          "past",
          "たかかった",
          "takakatta"
        ],
        [
          "past negative",
          "たかくなかった",
          "takakunakatta"
        ],
        [
          "polite negative",
          "たかくないです",
          "takakunai desu"
        ]
      ],
      "takeaway": "Drop final い, then add くない, かった, or くなかった."
    },
